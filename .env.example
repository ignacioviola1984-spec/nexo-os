# Nexo Operating Model v2 — environment configuration.
# Copy to `.env` (which is gitignored) and fill in. The build runs end-to-end on
# synthetic data with ONLY ANTHROPIC_API_KEY and the bootstrap admin set.

# --- Required to run agent narration (Spanish prose) ---
ANTHROPIC_API_KEY=

# --- Model used ONLY for narration (never for numbers) ---
NEXO_MODEL=claude-sonnet-4-6

# --- Data source: synthetic (default) | bigquery | gcs (bigquery/gcs fail closed w/o creds) ---
NEXO_DATA_SOURCE=synthetic

# --- Multi-tenancy: the active tenant. Each tenant's data is isolated in its own
#     store / dataset / GCS prefix. "default" keeps single-tenant paths. ---
NEXO_TENANT_ID=default

# --- Snapshot "as of" date override (YYYY-MM-DD). Defaults to the synthetic
#     dataset's documented snapshot date when unset. ---
# NEXO_SNAPSHOT_FECHA=2026-06-30

# --- First-boot bootstrap admin (provisions the initial dashboard seat).
#     Used once by `python -m nexo_os bootstrap-admin`. ---
NEXO_ADMIN_USERNAME=admin
NEXO_ADMIN_PASSWORD=
NEXO_ADMIN_NAME=Administrador

# --- Streamlit auth cookie (any random string; rotates sessions when changed) ---
NEXO_AUTH_COOKIE_KEY=change-me-to-a-random-secret

# --- BigQuery backend (optional, unused unless NEXO_DATA_SOURCE=bigquery) ---
# NEXO_BQ_PROJECT=
# NEXO_BQ_DATASET=nexo
# NEXO_BQ_CREDENTIALS_PATH=gcp-credentials.json

# --- Google Cloud Storage backend (optional, unused unless NEXO_DATA_SOURCE=gcs).
#     Domain extracts as Parquet at gs://<bucket>/<prefix><table>.parquet.
#     Install with: pip install -e ".[gcs]" ---
# NEXO_GCS_BUCKET=
# NEXO_GCS_PREFIX=nexo/
# NEXO_GCS_CREDENTIALS_PATH=gcp-credentials.json
