# Nexo Operating Model v2 — environment configuration.
# Copy to `.env` (which is gitignored) and fill in. The build runs end-to-end on
# synthetic data with ONLY ANTHROPIC_API_KEY and the bootstrap admin set.

# --- Required to run agent narration (Spanish prose) ---
ANTHROPIC_API_KEY=

# --- Model used ONLY for narration (never for numbers) ---
NEXO_MODEL=claude-sonnet-4-6

# --- Data source: synthetic (default, for PII reasons) | bigquery | gcs | turso
#     (bigquery, gcs and turso fail closed without their connection settings) ---
NEXO_DATA_SOURCE=synthetic

# --- Multi-tenancy: the active tenant. Each tenant's data is isolated in its own
#     store / dataset / GCS prefix. "default" keeps single-tenant paths. ---
NEXO_TENANT_ID=default

# --- Snapshot "as of" date override (YYYY-MM-DD). Defaults to the synthetic
#     dataset's documented snapshot date when unset. ---
# NEXO_SNAPSHOT_FECHA=2026-06-30

# --- First-boot bootstrap admin (provisions the initial dashboard seat).
#     Used once by `python -m nexo_os bootstrap-admin`. ---
NEXO_ADMIN_USERNAME=admin
NEXO_ADMIN_PASSWORD=
NEXO_ADMIN_NAME=Administrador

# --- Streamlit auth cookie (any random string; rotates sessions when changed) ---
NEXO_AUTH_COOKIE_KEY=change-me-to-a-random-secret

# --- BigQuery backend (optional, unused unless NEXO_DATA_SOURCE=bigquery) ---
# NEXO_BQ_PROJECT=
# NEXO_BQ_DATASET=nexo
# NEXO_BQ_CREDENTIALS_PATH=gcp-credentials.json

# --- Google Cloud Storage backend (optional, unused unless NEXO_DATA_SOURCE=gcs).
#     Domain extracts as Parquet at gs://<bucket>/<prefix><table>.parquet.
#     Install with: pip install -e ".[gcs]" ---
# NEXO_GCS_BUCKET=
# NEXO_GCS_PREFIX=nexo/
# NEXO_GCS_CREDENTIALS_PATH=gcp-credentials.json

# --- Turso / libSQL backend (optional). Install with `pip install -e ".[turso]"`.
#     URL is `libsql://<db>.turso.io` (remote, needs the auth token) or
#     `file:./nexo_turso.db` (local dev/test, no token). Seed with `nexo turso-seed`.
# NEXO_TURSO_DATABASE_URL=
# NEXO_TURSO_AUTH_TOKEN=
# --- Hybrid: keep domain on synthetic/bigquery but persist the system tables
#     (acciones, agent_runs, audit_log) in Turso. Set to `turso` to enable. ---
# NEXO_SYSTEM_STORE=default

# ======================= enterprise / production hardening ===================
# Every seam below fails closed: selecting it without its config raises rather than
# degrading silently. `production` tightens the security review and control checks.

# --- environment + release identity ---
NEXO_ENV=dev                       # dev | staging | production
NEXO_SERVICE_VERSION=2.0.0
# NEXO_GIT_SHA=                    # set by CI to the deployed commit (observability/rollback)

# --- SSO / OIDC (enterprise/sso.py). Default auth is the built-in password store. ---
NEXO_AUTH_MODE=password            # password | oidc
# NEXO_OIDC_ISSUER=https://accounts.google.com
# NEXO_OIDC_CLIENT_ID=
# NEXO_OIDC_CLIENT_SECRET=
# NEXO_OIDC_REDIRECT_URI=https://nexo.example.com/oauth2/callback
# NEXO_OIDC_SCOPES=openid email profile groups
# NEXO_OIDC_GROUPS_CLAIM=groups
# Set true ONLY behind a verifying identity-aware proxy (IAP/oauth2-proxy) that
# already validated the token. Otherwise install [sso] and verify locally.
# NEXO_OIDC_TRUST_PROXY_CLAIMS=false

# --- Cloud IAM: map IdP groups -> Nexo roles (enterprise/iam.py). Deny-by-default. ---
# Inline JSON, or a path to a JSON file. Values must be valid roles.
# NEXO_IAM_ROLE_BINDINGS={"nexo-admins":"admin","nexo-ops":"operador","nexo-audit":"auditor"}
# NEXO_IAM_BINDINGS_PATH=config/iam_bindings.json
# NEXO_IAM_DEFAULT_ROLE=            # role for a user matched by no binding (default: none)

# --- Secrets management + rotation (enterprise/secrets.py) ---
NEXO_SECRET_MANAGER=env            # env | gcp | aws | vault (cloud managers fail closed)
# NEXO_AUTH_COOKIE_KEY_PREVIOUS=   # previous key, valid during a rotation grace window
# NEXO_AUTH_COOKIE_KEY_ROTATED_ON=2026-07-02
NEXO_SECRET_MAX_AGE_DAYS=90

# --- Observability / monitoring (enterprise/observability.py) ---
NEXO_METRICS_ENABLED=true
NEXO_DATA_FRESHNESS_SLA_HOURS=48
